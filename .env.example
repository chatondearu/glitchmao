# Host/local app runtime
DATABASE_URL=postgresql://glitchmao:glitchmao@localhost:5432/glitchmao

# Docker compose runtimes
DATABASE_URL_DOCKER=postgresql://glitchmao:glitchmao@postgres:5432/glitchmao
DATABASE_URL_DOCKER_DEV=postgresql://glitchmao:glitchmao@postgres:5432/glitchmao
DATABASE_URL_DOCKER_PROD=postgresql://glitchmao:glitchmao@postgres:5432/glitchmao
DATABASE_URL_DOCKER_TEST=postgresql://glitchmao:glitchmao@postgres:5432/glitchmao_test
POSTGRES_USER=glitchmao
POSTGRES_PASSWORD=glitchmao
POSTGRES_DB=glitchmao
POSTGRES_DB_TEST=glitchmao_test
GPG_KEY_ID=test@glitchmao.local
SIGNER_DEFAULT_KEY_ID=test@glitchmao.local
SIGNER_SECURITY_MODE=secure
SIGNER_INSECURE_BIND=127.0.0.1
SIGNER_JWT_SECRET=change-me-in-env
SIGNER_JWT_TTL_SEC=60
SIGNER_HOST=0.0.0.0
SIGNER_PORT=4000
GNUPGHOME_DOCKER=/gnupg
GPG_HOME=
GPG_DEFAULT_KEY_NAME=GlitchMao User
GPG_DEFAULT_KEY_DOMAIN=glitchmao.local
SIGNER_SERVICE_URL=http://signer:4000
VERIFICATION_BASE_URL=http://localhost:3000/verify
STORAGE_PROVIDER=none
STORAGE_BUCKET=
STORAGE_BASE_URL=
CHOKIDAR_USEPOLLING=true
NPM_CONFIG_CACHE_DOCKER=/workspace/.npm-cache

# SMTP (Fastmail)
SMTP_HOST=smtp.fastmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=you@yourdomain.tld
SMTP_PASS=your-fastmail-app-password
SMTP_FROM=you@yourdomain.tld

PASSWORD_RESET_BASE_URL=http://localhost:3000/reset-password
